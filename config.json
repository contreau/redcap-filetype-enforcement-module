{
  "name": "REDCap File Type Enforcement External Module",
  "description": "Module that enforces configurable file/MIME types for file upload fields in survey instruments.",
  "namespace": "ExternalModules\\FiletypeEnforcementModule",
  "framework-version": 16,
  "authors": [
    {
      "name": "Conor Kelley",
      "email": "cfk102@gmail.com",
      "institution": "The George Washington University"
    }
  ],
  "auth-ajax-actions": [
    "get_enabled_filetypes",
    "get_enforced_filetypes",
    "get_filefield_settings",
    "set_filefield_settings",
    "sync_filefield",
    "sync_instrument",
    "update_fieldname",
    "update_instrument_name",
    "remove_filefield"
  ],
  "no-auth-ajax-actions": ["get_filefield_settings"],
  "project-settings": [
    {
      "key": "settings_description",
      "name": "<strong>INSTRUCTIONS:</strong> Check each file type that you would like to make available for your file upload fields. You can then choose among these in the instrument builder.<br/><br/><strong>IMPORTANT:</strong> If you have the Online Designer open while changing this configuration, you must refresh that page before continuing your instrument design.",
      "type": "descriptive"
    },
    {
      "key": "enable_pdf",
      "name": "Enable PDF files (.pdf)",
      "type": "checkbox"
    },
    {
      "key": "enable_word",
      "name": "Enable Word files (.doc, .docx)",
      "type": "checkbox"
    },
    {
      "key": "enable_excel",
      "name": "Enable Excel files (.xls, .xlsx)",
      "type": "checkbox"
    },
    {
      "key": "enable_csv",
      "name": "Enable CSV files (.csv)",
      "type": "checkbox"
    },
    {
      "key": "enable_text",
      "name": "Enable Text files (.txt, .text)",
      "type": "checkbox"
    },
    {
      "key": "enable_jpeg",
      "name": "Enable JPEG image files (.jpeg, .jpg)",
      "type": "checkbox"
    },
    {
      "key": "enable_png",
      "name": "Enable PNG Image files (.png)",
      "type": "checkbox"
    },
    {
      "key": "enable_tiff",
      "name": "Enable TIFF image files (.tiff, .tif)",
      "type": "checkbox"
    },
    {
      "key": "enable_powerpoint",
      "name": "Enable Powerpoint files (.ppt, .pptx)",
      "type": "checkbox"
    },
    {
      "key": "enable_rtf",
      "name": "Enable RTF files (.rtf)",
      "type": "checkbox"
    },
    {
      "key": "enable_dicom",
      "name": "Enable DICOM image files (.dcm)",
      "type": "checkbox"
    },
    {
      "key": "enable_bmp",
      "name": "Enable BMP image files (.bmp)",
      "type": "checkbox"
    },
    {
      "key": "enable_heic",
      "name": "Enable HEIC image files (.heic)",
      "type": "checkbox"
    },
    {
      "key": "enable_mp4",
      "name": "Enable MP4 video files (.mp4)",
      "type": "checkbox"
    },
    {
      "key": "enable_mp3",
      "name": "Enable MP3 audio files (.mp3)",
      "type": "checkbox"
    }
  ]
}
